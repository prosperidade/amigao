# Ambiente
ENVIRONMENT=production
SERVICE_NAME=api
SLOW_REQUEST_THRESHOLD_MS=500
SLOW_REQUEST_THRESHOLD_OVERRIDES=/api/v1/auth/login=2000,/api/v1/documents/upload-url=800,/api/v1/documents/confirm-upload=900

# Banco de dados
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=defina-uma-senha-forte-do-postgres
POSTGRES_DB=amigao_db
POSTGRES_PORT=5432

# Overrides opcionais para containers Docker
DOCKER_POSTGRES_SERVER=db
DOCKER_POSTGRES_PORT=5432
DOCKER_REDIS_URL=redis://redis:6379/0
DOCKER_MINIO_SERVER=minio:9000

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO / S3
MINIO_SERVER=minio:9000
MINIO_PUBLIC_URL=https://storage.seu-dominio.com
MINIO_ACCESS_KEY=defina-um-access-key-forte
MINIO_SECRET_KEY=defina-um-secret-key-forte
MINIO_SECURE=True

# JWT
SECRET_KEY=gere-uma-chave-com-pelo-menos-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.seu-provedor.com
SMTP_USER=usuario-smtp
SMTP_PASSWORD=senha-ou-token-smtp
EMAILS_FROM_EMAIL=noreply@seu-dominio.com
EMAILS_FROM_NAME=Amigao do Meio Ambiente

# URLs
CLIENT_PORTAL_URL=https://portal.seu-dominio.com/dashboard
BACKEND_CORS_ORIGINS=https://portal.seu-dominio.com,https://app.seu-dominio.com
API_BACKEND_URL=https://api.seu-dominio.com

# Observabilidade
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_MIN_SEVERITY=error
